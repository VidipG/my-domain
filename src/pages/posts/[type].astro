---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import NoteCard from '@/components/garden/NoteCard.astro';
import { NOTE_TYPES } from '../../content.config.ts';
import type { NoteType } from '../../content.config.ts';

interface TypeConfig {
  title:    string;
  h1:       string;
  description: string;
  colorCls: string;
}

const TYPE_CONFIG: Record<NoteType, TypeConfig> = {
  til: {
    title:       'TIL — Posts',
    h1:          'Today I Learned',
    description: 'Short notes on things I learned.',
    colorCls:    'text-gruv-blue-b',
  },
  technical: {
    title:       'Technical — Posts',
    h1:          'Technical Notes',
    description: 'In-depth notes on distributed systems, architecture, and programming.',
    colorCls:    'text-gruv-green-b',
  },
  freeform: {
    title:       'Freeform — Posts',
    h1:          'Freeform',
    description: 'Essays and extended explorations.',
    colorCls:    'text-gruv-yellow-b',
  },
};

export function getStaticPaths() {
  return NOTE_TYPES.map((type) => ({ params: { type } }));
}

const { type } = Astro.params as { type: NoteType };
const config = TYPE_CONFIG[type];

const notes = (await getCollection('notes', (n) => !n.data.draft && n.data.type === type))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<PageLayout title={config.title} description={config.description}>
  <main class="max-w-3xl mx-auto px-4 sm:px-8 lg:px-12 py-12 lg:py-16">
    <nav class="text-sm mb-6">
      <a href="/" class="text-gruv-fg4 hover:text-gruv-blue-b transition-colors">Home</a>
      <span class="text-gruv-bg3 mx-2">/</span>
      <a href="/posts" class="text-gruv-fg4 hover:text-gruv-blue-b transition-colors">Posts</a>
      <span class="text-gruv-bg3 mx-2">/</span>
      <span class={config.colorCls}>{config.h1}</span>
    </nav>

    <h1 class="text-4xl font-bold text-gruv-fg mb-2">{config.h1}</h1>
    <p class="text-gruv-fg4 text-lg mb-10">
      {config.description}
      {notes.length > 0 && <span class="opacity-60">{notes.length} {notes.length === 1 ? 'entry' : 'entries'}.</span>}
    </p>

    {notes.length > 0 ? (
      <ul class="flex flex-col gap-5">
        {notes.map((note) => <NoteCard note={note} />)}
      </ul>
    ) : (
      <p class="text-gruv-fg4">No notes yet — check back soon.</p>
    )}
  </main>
</PageLayout>
