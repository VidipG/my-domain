---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import NoteCard from '@/components/garden/NoteCard.astro';
import type { NoteType } from '../../content.config.ts';

const allNotes = await getCollection('notes', (n) => !n.data.draft);

const sorted = [...allNotes].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const tagFreq: Record<string, number> = {};
for (const note of sorted) {
  for (const tag of note.data.tags) {
    tagFreq[tag] = (tagFreq[tag] ?? 0) + 1;
  }
}
const topics = Object.entries(tagFreq)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);

const countByType: Record<NoteType, number> = { til: 0, technical: 0, freeform: 0 };
for (const n of allNotes) countByType[n.data.type]++;

const noteDataMap = Object.fromEntries(
  sorted.map((n) => [n.id, { type: n.data.type, tags: n.data.tags }])
);
---
<PageLayout
  title="Posts"
  description="Notes, ideas, and things I'm learning."
>
  <main class="max-w-6xl mx-auto px-4 sm:px-8 lg:px-12 py-12 lg:py-16">

    <header class="mb-10">
      <nav class="text-sm mb-6">
        <a href="/" class="text-gruv-fg4 hover:text-gruv-blue-b transition-colors">Home</a>
        <span class="text-gruv-bg3 mx-2">/</span>
        <span class="text-gruv-fg">Posts</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl font-bold text-gruv-fg mb-2">Posts</h1>
      <p class="text-gruv-fg4 text-lg mb-8 max-w-xl">
        Notes, ideas, and things I'm learning.
      </p>

      <div role="group" aria-label="Filter by type" class="flex flex-wrap gap-2">
        <button data-type=""          class="filter-btn filter-btn--active">All <span class="opacity-60">({allNotes.length})</span></button>
        <button data-type="til"       class="filter-btn">TIL <span class="opacity-60">({countByType.til})</span></button>
        <button data-type="technical" class="filter-btn">Technical <span class="opacity-60">({countByType.technical})</span></button>
        <button data-type="freeform"  class="filter-btn">Freeform <span class="opacity-60">({countByType.freeform})</span></button>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_200px] gap-8 lg:gap-12 items-start">

      <section class="min-w-0 w-full">
        <h2 class="text-xs text-gruv-fg4 uppercase tracking-widest mb-5">
          Recent
        </h2>
        <ul id="notes-list" class="flex flex-col gap-5 w-full">
          {sorted.map((note) => <NoteCard note={note} />)}
        </ul>
        <p id="empty-msg" class="hidden text-sm text-gruv-fg4 mt-6">No notes match this filter.</p>
      </section>

      <aside class="hidden lg:flex flex-col gap-10 sticky top-8">
        <div>
          <p class="text-xs text-gruv-fg4 uppercase tracking-widest mb-3">By Topic</p>
          <ul id="topic-list" class="flex flex-col gap-1">
            {topics.map((tag) => (
              <li data-tag={tag}>
                <button
                  data-topic={tag}
                  class="topic-btn text-left w-full font-mono text-sm px-2 py-1 rounded transition-colors text-gruv-fg4 hover:text-gruv-yellow"
                >
                  #{tag}
                  <span class="opacity-50 ml-1 text-xs" data-count>({tagFreq[tag]})</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      </aside>

    </div>

  </main>
</PageLayout>

<script is:inline define:vars={{ noteDataMap }}>
  const listEl   = document.getElementById('notes-list');
  const emptyMsg = document.getElementById('empty-msg');

  const noteItems = listEl
    ? Array.from(listEl.querySelectorAll('li')).map((li) => {
        const a = li.querySelector('a');
        const href = a?.getAttribute('href') ?? '';
        const id = href.replace(/^\/posts\//, '').replace(/\/$/, '');
        return { li, id };
      })
    : [];

  let activeType = '';
  let activeTag  = '';

  function applyFilters() {
    let visible = 0;
    for (const { li, id } of noteItems) {
      const data = noteDataMap[id] ?? { type: '', tags: [] };
      const show = (!activeType || data.type === activeType) && (!activeTag || data.tags.includes(activeTag));
      li.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    if (emptyMsg) emptyMsg.classList.toggle('hidden', visible > 0);
  }

  function updateTopicSidebar() {
    const tagCounts = {};
    for (const { id } of noteItems) {
      const data = noteDataMap[id] ?? { type: '', tags: [] };
      if (activeType && data.type !== activeType) continue;
      for (const tag of data.tags) {
        tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
      }
    }
    document.querySelectorAll('#topic-list li[data-tag]').forEach((li) => {
      const tag = li.dataset.tag ?? '';
      const count = tagCounts[tag] ?? 0;
      li.style.display = count > 0 ? '' : 'none';
      const countEl = li.querySelector('[data-count]');
      if (countEl) countEl.textContent = `(${count})`;
      if (count === 0 && activeTag === tag) {
        activeTag = '';
        li.querySelector('.topic-btn')?.classList.remove('topic-btn--active');
      }
    });
  }

  document.querySelectorAll('[data-type]').forEach((btn) => {
    btn.addEventListener('click', () => {
      activeType = btn.dataset.type ?? '';
      activeTag = '';
      document.querySelectorAll('.topic-btn').forEach((b) => b.classList.remove('topic-btn--active'));
      document.querySelectorAll('[data-type]').forEach((b) => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      updateTopicSidebar();
      applyFilters();
    });
  });

  document.querySelectorAll('.topic-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.topic ?? '';
      if (activeTag === tag) {
        activeTag = '';
        btn.classList.remove('topic-btn--active');
      } else {
        activeTag = tag;
        document.querySelectorAll('.topic-btn').forEach((b) => b.classList.remove('topic-btn--active'));
        btn.classList.add('topic-btn--active');
      }
      applyFilters();
    });
  });
</script>

<style>
  .filter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    min-width: 8rem;
    font-size: 0.875rem;
    font-family: var(--font-mono);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-gruv-bg2);
    background: var(--color-gruv-bg1);
    color: var(--color-gruv-fg4);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .filter-btn:hover { border-color: var(--color-gruv-bg3); color: var(--color-gruv-fg); }
  .filter-btn--active { border-color: var(--color-gruv-yellow); color: var(--color-gruv-yellow-b) !important; }

  .topic-btn { background: transparent; border: none; cursor: pointer; }
  .topic-btn--active { color: var(--color-gruv-yellow) !important; }
  .topic-btn:hover { background: var(--color-gruv-bg1); }
</style>
