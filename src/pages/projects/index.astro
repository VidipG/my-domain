---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import ProjectCard from '@/components/projects/ProjectCard.astro';

const allProjects = await getCollection('projects', (p) => !p.data.draft);

const sorted = [...allProjects].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Tags sorted by frequency
const tagFreq: Record<string, number> = {};
for (const project of sorted) {
  for (const tag of project.data.tags) {
    tagFreq[tag] = (tagFreq[tag] ?? 0) + 1;
  }
}
const topics = Object.entries(tagFreq)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);

const noteDataMap = Object.fromEntries(
  sorted.map((p) => [p.id, { tags: p.data.tags }])
);
---
<PageLayout
  title="Projects"
  description="Things I've built — side projects, experiments, and tools."
>
  <main class="max-w-6xl mx-auto px-4 sm:px-8 lg:px-12 py-12 lg:py-16">

    <header class="mb-10">
      <nav class="text-sm mb-6">
        <a href="/" class="text-gruv-fg4 hover:text-gruv-blue-b transition-colors">Home</a>
        <span class="text-gruv-bg3 mx-2">/</span>
        <span class="text-gruv-fg">Projects</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl font-bold text-gruv-fg mb-2">Projects</h1>
      <p class="text-gruv-fg4 text-lg mb-8 max-w-xl">
        Things I've built — side projects, experiments, and tools.
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_200px] gap-8 lg:gap-12 items-start">

      <!-- Project list -->
      <section class="min-w-0 w-full">
        <ul id="projects-list" class="flex flex-col gap-5 w-full">
          {sorted.map((project) => <ProjectCard project={project} />)}
        </ul>
        <p id="empty-msg" class="hidden text-sm text-gruv-fg4 mt-6">No projects for this topic.</p>
        {sorted.length === 0 && (
          <p class="text-gruv-fg4">No projects yet — check back soon.</p>
        )}
      </section>

      <!-- Sidebar (desktop only) -->
      {topics.length > 0 && (
        <aside class="hidden lg:block sticky top-8">
          <p class="text-xs text-gruv-fg4 uppercase tracking-widest mb-3">By Topic</p>
          <ul class="flex flex-col gap-1">
            {topics.map((tag) => (
              <li>
                <button
                  data-topic={tag}
                  class="topic-btn text-left w-full font-mono text-sm px-2 py-1 rounded transition-colors text-gruv-fg4 hover:text-gruv-yellow"
                >
                  #{tag}
                  <span class="opacity-50 ml-1 text-xs">({tagFreq[tag]})</span>
                </button>
              </li>
            ))}
          </ul>
        </aside>
      )}

    </div>

  </main>
</PageLayout>

<script is:inline define:vars={{ noteDataMap }}>
  const listEl   = document.getElementById('projects-list');
  const emptyMsg = document.getElementById('empty-msg');

  const items = listEl
    ? Array.from(listEl.querySelectorAll('li')).map((li) => {
        const a = li.querySelector('a');
        const href = a?.getAttribute('href') ?? '';
        const id = href.replace(/^\/projects\//, '').replace(/\/$/, '');
        return { li, id };
      })
    : [];

  let activeTag = '';

  function applyFilter() {
    let visible = 0;
    for (const { li, id } of items) {
      const data = noteDataMap[id] ?? { tags: [] };
      const show = !activeTag || data.tags.includes(activeTag);
      li.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    if (emptyMsg) emptyMsg.classList.toggle('hidden', visible > 0);
  }

  document.querySelectorAll('.topic-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.topic ?? '';
      if (activeTag === tag) {
        activeTag = '';
        document.querySelectorAll('.topic-btn').forEach((b) => b.classList.remove('topic-btn--active'));
      } else {
        activeTag = tag;
        document.querySelectorAll('.topic-btn').forEach((b) => b.classList.remove('topic-btn--active'));
        btn.classList.add('topic-btn--active');
      }
      applyFilter();
    });
  });
</script>

<style>
  .topic-btn {
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .topic-btn--active {
    color: var(--color-gruv-yellow) !important;
  }
  .topic-btn:hover {
    background: var(--color-gruv-bg1);
  }
</style>
