---
import BaseLayout from '@/layouts/BaseLayout.astro';
import KnowledgeGraph from '@/components/graph/KnowledgeGraph.astro';
import { getCollection } from 'astro:content';
import { buildSlugMap } from '@/lib/wikilinks';
import { buildGraphData } from '@/lib/graph';

const notes    = await getCollection('notes',    (n) => !n.data.draft);
const projects = await getCollection('projects', (p) => !p.data.draft);
const slugMap  = buildSlugMap(notes);
const graphData = buildGraphData(notes, slugMap, projects);
---
<BaseLayout
  title="vidip.dev"
  description="Software engineer. Writer. Builder. Digital garden of notes and ideas."
  noRss={false}
>
  <main style="display:grid; grid-template-columns:1fr 1fr; min-height:100dvh;">

    <!-- ── Left: Identity ──────────────────────────────────── -->
    <section style="display:flex; flex-direction:column; justify-content:center; padding:5rem 4rem 5rem 5rem;">

      <h1 class="text-5xl font-bold text-gruv-fg leading-none mb-4">
        Vidip
      </h1>

      <p class="text-gruv-fg4 text-xl mb-10 max-w-xs leading-relaxed">
        Software engineer. I write about distributed systems, the web, and how I think about building things.
      </p>

      <nav aria-label="Primary navigation" style="display:flex; flex-direction:column; gap:0.75rem;">
        {[
          { href: '/garden',   label: 'Digital Garden', sub: 'Notes & ideas' },
          { href: '/projects', label: 'Projects',       sub: 'Things I\'ve built' },
          { href: '/uses',     label: 'Uses',           sub: 'Tools & setup' },
        ].map(({ href, label, sub }) => (
          <a
            href={href}
            class="group flex items-center gap-3 text-gruv-fg hover:text-gruv-yellow-b transition-colors"
          >
            <span class="text-gruv-bg3 group-hover:text-gruv-yellow transition-colors">→</span>
            <span>
              <span class="font-semibold">{label}</span>
              <span class="text-gruv-fg4 text-sm ml-2">{sub}</span>
            </span>
          </a>
        ))}
      </nav>

      <!-- Social icons -->
      <div style="display:flex; align-items:center; gap:1.25rem; margin-top:3rem;">
        <!-- Email -->
        <a href="mailto:vg@vidipg.com" aria-label="Email" class="text-gruv-fg4 hover:text-gruv-fg transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </a>
        <!-- GitHub -->
        <a href="https://github.com/vidipgg" rel="noopener noreferrer" aria-label="GitHub" class="text-gruv-fg4 hover:text-gruv-fg transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.004.07 1.532 1.032 1.532 1.032.891 1.529 2.341 1.087 2.91.831.091-.646.349-1.086.635-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </a>
        <!-- LinkedIn -->
        <a href="https://linkedin.com/in/vidip" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gruv-fg4 hover:text-gruv-fg transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <!-- Bluesky -->
        <a href="https://bsky.app/profile/vidip.dev" rel="noopener noreferrer" aria-label="Bluesky" class="text-gruv-fg4 hover:text-gruv-fg transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
          </svg>
        </a>
        <!-- Mastodon -->
        <a href="https://mastodon.social/@vidip" rel="noopener noreferrer" aria-label="Mastodon" class="text-gruv-fg4 hover:text-gruv-fg transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.498l.638 1.06.638-1.06c.66-.999 1.65-1.498 2.96-1.498 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"/>
          </svg>
        </a>
      </div>

    </section>

    <!-- ── Right: Knowledge Graph ──────────────────────────── -->
    <section
      style="display:flex; align-items:center; justify-content:center; padding:2rem; border-left:1px solid var(--color-gruv-bg2);"
      aria-label="Knowledge graph"
    >
      <KnowledgeGraph data={graphData} width={560} height={480} />
    </section>

  </main>
</BaseLayout>
