---
/**
 * PageLayout — generic page chrome (header nav, main, footer).
 * Wraps BaseLayout. Use for non-note pages: garden index, resume, uses, etc.
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noRss?: boolean;
}

const props = Astro.props;
---
<BaseLayout {...props}>
  <slot name="head" slot="head" />

  <div class="min-h-dvh flex flex-col">
    <slot />
  </div>
</BaseLayout>
