---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '@/components/garden/TagBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, date, tags, url } = project.data;

const formatted = date.toLocaleDateString('en-US', {
  year:  'numeric',
  month: 'long',
});
---
<BaseLayout {title} {description} canonical={`${Astro.site}projects/${project.id}/`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-8 lg:px-12 py-12 lg:py-16">

    <article>
      <header class="mb-10">
        <nav class="text-sm mb-6">
          <a href="/" class="text-gruv-fg4 hover:text-gruv-blue-b transition-colors">Home</a>
          <span class="text-gruv-bg3 mx-2">/</span>
          <a href="/projects" class="text-gruv-fg4 hover:text-gruv-blue-b transition-colors">Projects</a>
          <span class="text-gruv-bg3 mx-2">/</span>
          <span class="text-gruv-fg4">{title}</span>
        </nav>

        <div class="flex items-center gap-3 mb-3">
          <time datetime={date.toISOString()} class="text-xs text-gruv-fg4 font-mono">{formatted}</time>
          {url && (
            <a
              href={url}
              rel="noopener noreferrer"
              class="text-xs font-mono text-gruv-blue-b hover:underline ml-auto"
            >
              ↗ View project
            </a>
          )}
        </div>

        <h1 class="text-3xl font-bold text-gruv-fg leading-tight mb-3">
          {title}
        </h1>

        <p class="text-gruv-fg4 text-lg mb-5">{description}</p>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((t) => <TagBadge tag={t} />)}
          </div>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>

  </div>
</BaseLayout>
