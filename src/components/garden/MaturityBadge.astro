---
import type { NoteMaturity } from '../../content.config.ts';

interface Props {
  maturity: NoteMaturity;
}

const { maturity } = Astro.props;

const CONFIG: Record<NoteMaturity, { icon: string; label: string; cls: string }> = {
  seedling:  { icon: '🌱', label: 'Seedling',  cls: 'text-gruv-green' },
  budding:   { icon: '🌿', label: 'Budding',   cls: 'text-gruv-yellow' },
  evergreen: { icon: '🌲', label: 'Evergreen', cls: 'text-gruv-aqua-b' },
};

const { icon, label, cls } = CONFIG[maturity];
---
<span
  class={`inline-flex items-center gap-1 text-xs font-mono ${cls}`}
  title={label}
  aria-label={label}
>
  <span aria-hidden="true">{icon}</span>
  {label}
</span>
